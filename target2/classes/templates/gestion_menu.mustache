<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/general.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/gestion_menu.css">
    <link rel="stylesheet" href="/css/menu.css">
</head>

<body class="body-content">
    {{> fragments/header}}

    <main class="container my-5 admin-container">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2>Gestión de Productos</h2>
            <button class="btn btn-header"
                onclick="document.getElementById('productForm').scrollIntoView({behavior: 'smooth'})">
                <i class="fas fa-plus me-2"></i>Nuevo Producto
            </button>
        </div>

        <!-- Product Form -->
        <div id="productForm" class="row justify-content-center mb-5">
            <div class="col-lg-8">
                <h4 class="mb-4">Agregar Producto</h4>
                <div class="form-container">
                    <form id="productFormEl" action="/gestion_menu/add" method="POST">
                        <input type="hidden" id="productId" name="id">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="productName" class="form-label">Nombre del Producto</label>
                                <input type="text" class="form-control" id="productName" name="name"
                                    placeholder="Ej: Café Mokaf Especial" required>
                            </div>
                            <div class="col-md-6">
                                <label for="productCategory" class="form-label">Categoría</label>
                                <select class="form-select" id="productCategory" name="category" required>
                                    <option value="" selected disabled>Seleccionar...</option>
                                    <option value="Hot">Calientes</option>
                                    <option value="Cold">Fríos</option>
                                    <option value="Blended">Mezclados</option>
                                    <option value="Desserts">Postres</option>
                                    <option value="Non-Coffee">Sin Café</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label for="productPrice" class="form-label">Precio (€)</label>
                                <input type="text" class="form-control" id="productPrice" name="price"
                                    placeholder="0.00" required>
                            </div>
                            <div class="col-md-8">
                                <label for="productImage" class="form-label">URL de Imagen</label>
                                <input type="text" class="form-control" id="productImage" name="image"
                                    placeholder="/images/MenuImages/..." required>
                            </div>

                            <div class="col-12">
                                <label for="productDescription" class="form-label">Descripción</label>
                                <textarea class="form-control" id="productDescription" name="description" rows="3"
                                    placeholder="Descripción breve del producto..." required></textarea>
                            </div>

                            <div class="col-12 mt-4 d-flex justify-content-end gap-2">
                                <button type="button" class="btn btn-secondary d-none" id="cancelEditBtn">Cancelar Edición</button>
                                <button type="submit" class="btn btn-header" id="submitBtn">Guardar Producto</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Product List -->
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th scope="col">Imagen</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Categoría</th>
                        <th scope="col">Precio</th>
                        <th scope="col" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#items}}
                    <tr>
                        <td><img src="{{image}}" class="product-thumb" alt="{{name}}"></td>
                        <td>{{name}}</td>
                        <td><span class="badge bg-secondary">{{category}}</span></td>
                        <td>{{basePrice}}</td>
                        <td class="text-end">
                            <button class="btn btn-action btn-edit" 
                                onclick="editProduct('{{id}}', '{{name}}', '{{category}}', '{{basePrice}}', '{{image}}', '{{description}}')">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form action="/gestion_menu/delete/{{id}}" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-action btn-delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    {{/items}}
                </tbody>
            </table>
        </div>

        <script>
            function editProduct(id, name, category, price, image, description) {
                // Populate form
                document.getElementById('productId').value = id;
                document.getElementById('productName').value = name;
                document.getElementById('productCategory').value = category;
                // Cleanup price string (remove € symbol if present for number input)
                document.getElementById('productPrice').value = price.replace('€', '').trim();
                document.getElementById('productImage').value = image;
                document.getElementById('productDescription').value = description;

                // Change UI state
                document.getElementById('submitBtn').innerText = 'Actualizar Producto';
                document.getElementById('cancelEditBtn').classList.remove('d-none');
                
                // Change form action
                document.getElementById('productFormEl').action = '/gestion_menu/edit';

                // Scroll to form
                document.getElementById('productForm').scrollIntoView({behavior: 'smooth'});
            }

            document.getElementById('cancelEditBtn').addEventListener('click', function() {
                // Reset form
                document.getElementById('productFormEl').reset();
                document.getElementById('productId').value = '';

                // Reset UI state
                document.getElementById('submitBtn').innerText = 'Guardar Producto';
                this.classList.add('d-none');

                // Reset form action
                document.getElementById('productFormEl').action = '/gestion_menu/add';
            });
        </script>

        <hr class="my-5" style="border-color: var(--dorado); opacity: 0.3;">

        {{> fragments/footer}}

</body>

</html>
