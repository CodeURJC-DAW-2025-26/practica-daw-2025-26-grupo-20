<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mokaf - Mis Pedidos</title>

    <!-- Aquí enlazas tu CSS global -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/general.css">
    <link rel="stylesheet" href="css/banner.css">
    <link rel="stylesheet" href="css/footer.css">
</head>

<body class="body-content">
     {{> fragments/header}}

    <!-- Main Content -->
    <main class="container my-5">
        <!-- Page Title -->
        <div class="text-center mb-5">
            <h2 class="text-center mb-5">Historial de Pedidos</h2>
         
        </div>

        <!-- Orders List -->
            <div class="row g-4">

            {{#orders}}
            <div class="col-12">
                <div class="card shadow-sm border-0">

                    <div class="card-header bg-white border-bottom py-3">
                        <div class="row align-items-center">

                            <div class="col-md-3">
                                <h5 class="mb-0 fw-bold">
                                    Pedido #{{id}}
                                </h5>
                            </div>

                            <div class="col-md-3">
                                <p class="mb-0 text-muted">
                                    Fecha: {{createdAt}}
                                </p>
                            </div>

                            <div class="col-md-3">
                                <p class="mb-0 text-muted">
                                    Cliente: <strong>{{user.name}}</strong>
                                </p>
                            </div>

                            <div class="col-md-3">
                                <span class="badge bg-success">
                                    {{status}}
                                </span>
                            </div>

                        </div>
                    </div>

                    <div class="card-body p-4">

                        <div class="mb-3">
                            <h6 class="fw-bold">Sucursal</h6>
                            <p class="text-muted ms-3">
                                {{branch.name}}
                            </p>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Producto</th>
                                        <th>Cantidad</th>
                                        <th class="text-end">Precio</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>

                                {{#items}}
                                    <tr>
                                        <td>{{product.name}}</td>
                                        <td>{{quantity}}</td>
                                        <td class="text-end">{{finalUnitPrice}}€</td>
                                        <td class="text-end">{{lineTotal}}€</td>
                                    </tr>
                                {{/items}}

                                </tbody>
                            </table>
                        </div>

                        <div class="text-end mt-3">
                            <h5 class="fw-bold">
                                Total: {{totalAmount}}€
                            </h5>
                        </div>

                    </div>

                </div>
            </div>
            {{/orders}}

            {{^orders}}
            <div class="text-center py-5">
                <h3>No tienes pedidos pagados</h3>
            </div>
            {{/orders}}

            </div>

        <!-- Empty State (optional - hide if there are orders) -->
        <!-- <div class="text-center py-5" style="display: none;">
            <i class="fas fa-shopping-bag text-muted" style="font-size: 5rem;"></i>
            <h3 class="mt-4 text-muted">No tienes pedidos aún</h3>
            <p class="text-muted">Cuando realices tu primer pedido, aparecerá aquí</p>
            <a href="menu.html" class="btn btn-primary mt-3">Ver Menú</a>
        </div> -->
    </main>

     {{> fragments/footer}}

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>