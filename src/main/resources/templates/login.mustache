<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{title}}</title>

        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        >
        <link rel="stylesheet" href="/css/login.css">
        <link rel="stylesheet" href="/css/general.css">
        <link rel="stylesheet" href="/css/footer.css">
    </head>
    <body class="login-page d-flex flex-column min-vh-100">
        {{> fragments/header}}

        <main class="flex-grow-1">
            <section class="container login-container my-5">
                <h2 class="text-center">Login o Registro</h2>

                <!-- Mensajes -->
                {{#errorMessage}}
                    <div
                        class="alert alert-danger alert-dismissible fade show"
                        role="alert"
                    >
                        {{errorMessage}}
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="alert"
                        ></button>
                    </div>
                {{/errorMessage}}

                {{#logoutMessage}}
                    <div
                        class="alert alert-success alert-dismissible fade show"
                        role="alert"
                    >
                        {{logoutMessage}}
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="alert"
                        ></button>
                    </div>
                {{/logoutMessage}}

                {{#registeredMessage}}
                    <div
                        class="alert alert-success alert-dismissible fade show"
                        role="alert"
                    >
                        {{registeredMessage}}
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="alert"
                        ></button>
                    </div>
                {{/registeredMessage}}

                {{#deletedMessage}}
                    <div
                        class="alert alert-info alert-dismissible fade show"
                        role="alert"
                    >
                        {{deletedMessage}}
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="alert"
                        ></button>
                    </div>
                {{/deletedMessage}}

                <div class="row">
                    <!-- LOGIN -->
                    <div class="col-md-6">
                        <div class="auth-card p-4 h-100">
                            <h4 class="mb-4">Login</h4>
                            <form action="/login" method="post" id="loginForm">
                                {{#_csrf}}
                                    <input
                                        type="hidden"
                                        name="{{_csrf.parameterName}}"
                                        value="{{_csrf.token}}"
                                    />
                                {{/_csrf}}

                                <div class="mb-3">
                                    <label for="loginEmail" class="form-label">
                                        Email
                                    </label>
                                    <input
                                        type="email"
                                        class="form-control"
                                        id="loginEmail"
                                        name="email"
                                        placeholder="Tu email"
                                        required
                                    >
                                </div>
                                <div class="mb-4">
                                    <label
                                        for="loginPassword"
                                        class="form-label"
                                    >
                                        Contraseña
                                    </label>
                                    <input
                                        type="password"
                                        class="form-control"
                                        id="loginPassword"
                                        name="password"
                                        placeholder="Tu contraseña"
                                        required
                                    >
                                    <small class="text-muted d-block mt-1">
                                        Debe contener letras y números
                                    </small>
                                </div>
                                <button
                                    type="submit"
                                    class="btn btn-primary w-100"
                                >
                                    Login
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- REGISTRO -->
                    <div class="col-md-6">
                        <div class="auth-card p-4 h-100">
                            <h4 class="mb-4">Registro</h4>
                            <form
                                action="/register"
                                method="post"
                                id="registerForm"
                            >
                                {{#_csrf}}
                                    <input
                                        type="hidden"
                                        name="{{_csrf.parameterName}}"
                                        value="{{_csrf.token}}"
                                    />
                                {{/_csrf}}

                                <div class="mb-3">
                                    <label
                                        for="registerName"
                                        class="form-label"
                                    >
                                        Nombre completo
                                    </label>
                                    <input
                                        type="text"
                                        class="form-control"
                                        id="registerName"
                                        name="name"
                                        placeholder="Tu nombre completo"
                                        required
                                    >
                                </div>
                                <div class="mb-3">
                                    <label
                                        for="registerEmail"
                                        class="form-label"
                                    >
                                        Email
                                    </label>
                                    <input
                                        type="email"
                                        class="form-control"
                                        id="registerEmail"
                                        name="email"
                                        placeholder="Tu email"
                                        required
                                    >
                                </div>
                                <div class="mb-4">
                                    <label
                                        for="registerPassword"
                                        class="form-label"
                                    >
                                        Contraseña
                                    </label>
                                    <input
                                        type="password"
                                        class="form-control"
                                        id="registerPassword"
                                        name="password"
                                        placeholder="Mín. 4 caracteres"
                                        minlength="4"
                                        required
                                    >
                                    <small class="text-muted d-block mt-1">
                                        Debe contener letras y números
                                    </small>
                                </div>
                                <button
                                    type="submit"
                                    class="btn btn-success w-100"
                                >
                                    Registrarse
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        {{> fragments/footer}}

        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        ></script>
        <script>
            const passwordRegex = /^.*(?=.*[a-zA-Z])(?=.*\d).*$/;
            
            document.getElementById('loginForm').addEventListener('submit', function (e) {
                const pwd = document.getElementById('loginPassword').value;
                if (!passwordRegex.test(pwd)) {
                    e.preventDefault();
                    alert('La contraseña debe contener letras y números.');
                }
            });
            
            document.getElementById('registerForm').addEventListener('submit', function (e) {
                const pwd = document.getElementById('registerPassword').value;
                if (!passwordRegex.test(pwd)) {
                    e.preventDefault();
                    alert('La contraseña debe contener letras y números.');
                }
            });
        </script>
    </body>
</html>
