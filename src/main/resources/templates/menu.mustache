<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{title}}</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        >
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
        >
        <link rel="stylesheet" href="/css/general.css">
        <link rel="stylesheet" href="/css/footer.css">
        <link rel="stylesheet" href="/css/menu.css">
    </head>
    <body class="body-content">
        {{> fragments/header}}

        <main class="container my-5 menu-container">
            <h2 class="text-center mb-5">Nuestro Menú</h2>

            <!-- Recommended Products Section -->
            {{#recommendedItems.0}}
                <section class="recommended-section mb-5">
                    <div class="recommended-header">
                        <h3>
                            <i class="fas fa-star text-warning me-2"></i>Recomendados
                            para ti
                        </h3>
                        <p class="text-muted">
                            Basado en las preferencias de nuestros clientes
                        </p>
                    </div>

                    <div
                        class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mt-2"
                    >
                        {{#recommendedItems}}
                            <a
                                class="product-link text-decoration-none text-dark"
                                href="/product/{{id}}"
                            >
                                <div class="col">
                                    <div class="card h-100 recommended-card">
                                        {{#image}}
                                            <img
                                                src="/images/{{id}}"
                                                class="card-img-top"
                                                alt="{{name}}"
                                                onerror="this.src='/images/placeholder.jpg'"
                                            >
                                        {{/image}}
                                        {{^image}}
                                            <img
                                                src="/images/placeholder.jpg"
                                                class="card-img-top"
                                                alt="{{name}}"
                                            >
                                        {{/image}}

                                        <div
                                            class="card-body d-flex flex-column"
                                        >
                                            <h5 class="card-title">{{name}}</h5>
                                            <div
                                                class="price-action-wrapper mt-auto"
                                            >
                                                <span class="price-tag">
                                                    {{priceBase}}€
                                                </span>
                                                {{#user}}
                                                    <form
                                                        action="/cart/add"
                                                        method="POST"
                                                        class="d-inline ajax-cart-form"
                                                    >
                                                        <input
                                                            type="hidden"
                                                            name="productId"
                                                            value="{{id}}"
                                                        >
                                                        <input
                                                            type="hidden"
                                                            name="qty"
                                                            value="1"
                                                        >
                                                        <button
                                                            type="submit"
                                                            class="btn btn-sm btn-recommended-cart"
                                                            onclick="event.stopPropagation();"
                                                        >
                                                            <i
                                                                class="fas fa-cart-plus me-1"
                                                            ></i> Añadir
                                                        </button>
                                                    </form>
                                                {{/user}}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        {{/recommendedItems}}
                    </div>
                </section>
            {{/recommendedItems.0}}

            <!-- Category Navigation -->
            <div class="category-nav mb-4">
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    <button class="btn btn-category active" data-category="all">
                        Todos
                    </button>
                    <button class="btn btn-category" data-category="HOT">
                        Calientes
                    </button>
                    <button class="btn btn-category" data-category="COLD">
                        Fríos
                    </button>
                    <button class="btn btn-category" data-category="BLENDED">
                        Mezclados
                    </button>
                    <button class="btn btn-category" data-category="DESSERTS">
                        Postres
                    </button>
                    <button class="btn btn-category" data-category="NON_COFFEE">
                        Sin Café
                    </button>
                </div>
            </div>

            <!-- Allergen Filter (Exclusion) -->
            <div class="allergen-filter-nav mb-5 text-center">
                <h6
                    class="text-muted mb-3"
                    style="color: var(--dorado) !important;"
                >
                    Ocultar productos que contengan:
                </h6>
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    {{#allergens}}
                        <button
                            class="badge rounded-pill allergen-filter-btn text-white"
                            data-allergen="{{name}}"
                            title="Click para excluir productos con {{name}}"
                            style="border: 2px solid transparent; opacity: 0.6; cursor: pointer; transition: all 0.2s; font-size: 0.9em; padding: 8px 15px;"
                        >
                            {{name}}
                        </button>
                    {{/allergens}}
                    {{^allergens}}
                        <span class="text-muted mt-1">
                            <small>No hay alérgenos registrados.</small>
                        </span>
                    {{/allergens}}
                </div>
            </div>

            <!-- Menu Items Grid -->
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                {{#items}}
                    <div class="col menu-item" data-category="{{category}}">
                        <a class="product-link" href="/product/{{id}}">
                            <div class="card h-100 menu-card">
                                {{#image}}
                                    <img
                                        src="/images/{{id}}"
                                        class="card-img-top"
                                        alt="{{name}}"
                                        onerror="this.src='https://via.placeholder.com/300x200?text={{name}}'"
                                    >
                                {{/image}}
                                {{^image}}
                                    <img
                                        src="https://via.placeholder.com/300x200?text={{name}}"
                                        class="card-img-top"
                                        alt="{{name}}"
                                    >
                                {{/image}}

                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">{{name}}</h5>
                                    <p class="card-text">{{description}}</p>

                                    <!-- Hidden allergens elements for Javascript filtering logic -->
                                    <div
                                        class="d-none allergens-data-container"
                                    >
                                        {{#allergens}}
                                            <span
                                                class="allergen-badge"
                                                data-allergen="{{name}}"
                                            ></span>
                                        {{/allergens}}
                                    </div>

                                    <div
                                        class="mt-auto d-flex justify-content-between align-items-center"
                                    >
                                        <p class="card-price fw-bold mb-0">
                                            {{priceBase}}€
                                        </p>

                                        {{#user}}
                                            <form
                                                action="/cart/add"
                                                method="POST"
                                                class="d-inline ajax-cart-form"
                                            >
                                                <input
                                                    type="hidden"
                                                    name="productId"
                                                    value="{{id}}"
                                                >
                                                <input
                                                    type="hidden"
                                                    name="qty"
                                                    value="1"
                                                >
                                                <button
                                                    type="submit"
                                                    class="btn btn-sm btn-outline-primary btn-add-cart"
                                                    onclick="event.stopPropagation();"
                                                >
                                                    <i
                                                        class="fas fa-cart-plus me-1"
                                                    ></i> Añadir
                                                </button>
                                            </form>
                                        {{/user}}
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                {{/items}}
            </div>
        </main>

        {{> fragments/footer}}

        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        ></script>
        <script src="/js/cart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Function to get a consistent color for each allergen
                const colors = ['#e63946', '#f4a261', '#2a9d8f', '#264653', '#e76f51', '#8ab17d'];
                function getColorForAllergen(allergenName) {
                    let hash = 0;
                    for (let i = 0; i < allergenName.length; i++) {
                        hash = allergenName.charCodeAt(i) + ((hash << 5) - hash);
                    }
                    const colorIndex = Math.abs(hash) % colors.length;
                    return colors[colorIndex];
                }
            
                // Apply colors to allergen filter buttons on load
                document.querySelectorAll('.allergen-filter-btn').forEach(btn => {
                    const allergenName = btn.getAttribute('data-allergen');
                    btn.style.backgroundColor = getColorForAllergen(allergenName);
                });
            
                const filterBtns = document.querySelectorAll('.btn-category');
                const allergenFilterBtns = document.querySelectorAll('.allergen-filter-btn');
                const menuItems = document.querySelectorAll('.menu-item');
            
                let currentCategory = 'all';
                const excludedAllergens = new Set();
            
                function applyFilters() {
                    menuItems.forEach(item => {
                        const itemCat = item.getAttribute('data-category');
                        const itemAllergens = Array.from(item.querySelectorAll('.allergen-badge')).map(badge => badge.getAttribute('data-allergen'));
            
                        const matchesCategory = (currentCategory === 'all' || itemCat === currentCategory);
                        const hasExcludedAllergen = itemAllergens.some(allergen => excludedAllergens.has(allergen));
            
                        if (matchesCategory && !hasExcludedAllergen) {
                            item.style.display = '';
                        } else {
                            item.style.display = 'none';
                        }
                    });
                }
            
                // Category filter functionality
                filterBtns.forEach(btn => {
                    btn.addEventListener('click', () => {
                        filterBtns.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
            
                        currentCategory = btn.getAttribute('data-category');
                        applyFilters();
                    });
                });
            
                // Allergen filter functionality
                allergenFilterBtns.forEach(btn => {
                    btn.addEventListener('click', () => {
                        const allergen = btn.getAttribute('data-allergen');
                        if (excludedAllergens.has(allergen)) {
                            excludedAllergens.delete(allergen);
                            btn.style.opacity = '0.6';
                            btn.style.transform = 'scale(1)';
                            btn.style.border = '2px solid transparent';
                            btn.innerHTML = btn.getAttribute('data-allergen');
                        } else {
                            excludedAllergens.add(allergen);
                            btn.style.opacity = '1';
                            btn.style.transform = 'scale(1.05)';
                            btn.style.border = '2px solid var(--marron-oscuro)';
                            btn.innerHTML = `<i class="fas fa-ban me-1"></i> ${btn.getAttribute('data-allergen')}`;
                        }
                        applyFilters();
                    });
                });
            
                // Initialize AJAX cart
                initCart();
            
                // Deep linking: apply filter based on hash
                function checkHash() {
                    const hash = window.location.hash.substring(1);
                    if (hash) {
                        const targetBtn = document.querySelector(`.btn-category[data-category="${hash}"]`);
                        if (targetBtn) {
                            filterBtns.forEach(b => b.classList.remove('active'));
                            targetBtn.classList.add('active');
                            currentCategory = hash;
                            applyFilters();
            
                            // Scroll to menu container if hash is present
                            document.querySelector('.menu-container').scrollIntoView({ behavior: 'smooth' });
                        }
                    }
                }
            
                // Initial check
                checkHash();
            
                // Listen for hash changes
                window.addEventListener('hashchange', checkHash);
            });
        </script>
    </body>
</html>
