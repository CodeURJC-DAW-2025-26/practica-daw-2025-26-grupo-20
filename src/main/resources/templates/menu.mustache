<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{title}}</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        >
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
        >
        <link rel="stylesheet" href="/css/general.css">
        <link rel="stylesheet" href="/css/footer.css">
        <link rel="stylesheet" href="/css/menu.css">
    </head>
    <body class="body-content">
        {{> fragments/header}}

        <!-- Recommended Products Section -->
        {{#recommendedItems.0}}
        <section class="recommended-section mb-5">
            <div class="recommended-header">
                <h3><i class="fas fa-star text-warning me-2"></i>Recomendados para ti</h3>
                <p class="text-muted">Basado en las preferencias de nuestros clientes</p>
            </div>
            
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mt-2">
                {{#recommendedItems}}
                <a class="product-link text-decoration-none text-dark" href="/product/{{id}}">
                    <div class="col">
                        <div class="card h-100 recommended-card">
                            {{#image}}
                            <img src="/images/{{id}}" class="card-img-top" alt="{{name}}"
                                 onerror="this.src='/images/placeholder.jpg'">
                            {{/image}}
                            {{^image}}
                            <img src="/images/placeholder.jpg" class="card-img-top" alt="{{name}}">
                            {{/image}}

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">{{name}}</h5>
                                <div class="price-action-wrapper mt-auto">
                                    <span class="price-tag">{{priceBase}}€</span>
                                    <form action="/cart/add" method="POST" class="d-inline">
                                        <input type="hidden" name="productId" value="{{id}}">
                                        <input type="hidden" name="qty" value="1">
                                        {{#user}}
                                        <button type="submit" class="btn btn-sm btn-recommended-cart"
                                                onclick="event.stopPropagation();">
                                            <i class="fas fa-cart-plus me-1"></i> Añadir
                                        </button>
                                        {{/user}}
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
                {{/recommendedItems}}
            </div>
        </section>
        {{/recommendedItems.0}}

            <!-- Category Navigation -->
            <div class="category-nav mb-4">
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    <button class="btn btn-category active" data-category="all">
                        Todos
                    </button>
                    <button class="btn btn-category" data-category="HOT">
                        Calientes
                    </button>
                    <button class="btn btn-category" data-category="COLD">
                        Fríos
                    </button>
                    <button class="btn btn-category" data-category="BLENDED">
                        Mezclados
                    </button>
                    <button class="btn btn-category" data-category="DESSERTS">
                        Postres
                    </button>
                    <button class="btn btn-category" data-category="NON_COFFEE">
                        Sin Café
                    </button>
                </div>
            </div>

            <!-- Allergen Filter (Exclusion) -->
            <div class="allergen-filter-nav mb-5 text-center">
                <h6
                    class="text-muted mb-3"
                    style="color: var(--dorado) !important;"
                >
                    Ocultar productos que contengan:
                </h6>
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    {{#allergens}}
                        <button
                            class="badge rounded-pill allergen-filter-btn text-white"
                            data-allergen="{{name}}"
                            title="Click para excluir productos con {{name}}"
                            style="border: 2px solid transparent; opacity: 0.6; cursor: pointer; transition: all 0.2s; font-size: 0.9em; padding: 8px 15px;"
                        >
                            {{name}}
                        </button>
                    {{/allergens}}
                    {{^allergens}}
                        <span class="text-muted mt-1">
                            <small>No hay alérgenos registrados.</small>
                        </span>
                    {{/allergens}}
                </div>
            </div>

            <!-- Menu Items Grid -->
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                {{#items}}
                    <div class="col menu-item" data-category="{{category}}">
                        <a class="product-link" href="/product/{{id}}">
                            <div class="card h-100 menu-card">
                                {{#image}}
                                    <img
                                        src="/images/{{id}}"
                                        class="card-img-top"
                                        alt="{{name}}"
                                        onerror="this.src='https://via.placeholder.com/300x200?text={{name}}'"
                                    >
                                {{/image}}
                                {{^image}}
                                    <img
                                        src="https://via.placeholder.com/300x200?text={{name}}"
                                        class="card-img-top"
                                        alt="{{name}}"
                                    >
                                {{/image}}

        <!-- Recommended Products Section -->
        {{#recommendedItems.0}}
        <section class="recommended-section mb-5">
            <div class="recommended-header">
                <h3><i class="fas fa-star text-warning me-2"></i>Recomendados para ti</h3>
                <p class="text-muted">Basado en las preferencias de nuestros clientes</p>
            </div>
            
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mt-2">
