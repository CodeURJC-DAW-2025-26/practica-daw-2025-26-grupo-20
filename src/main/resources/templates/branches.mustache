<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mokaf - Nuestras Sucursales</title>

    <!-- CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/general.css">
    <link rel="stylesheet" href="/css/footer.css">
    
    <style>
        :root {
            --cafe-oscuro: #3A2A1D;
            --cafe-medio: #5D4037;
            --cafe-claro: #8B6B61;
            --negro: #1A1A1A;
            --beige: #D7CCC8;
            --dorado: #C6A87D;
        }

        .branches-container {
            background-color: rgba(26, 26, 26, 0.85);
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 1px solid var(--dorado);
            max-width: 1200px;
            margin: 2rem auto;
        }

        .branches-title {
            color: var(--dorado);
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 2rem;
            position: relative;
            padding-bottom: 15px;
            text-align: center;
        }

        .branches-title:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 2px;
            background: linear-gradient(to right, transparent, var(--dorado), transparent);
        }

        .branch-card {
            background-color: rgba(58, 42, 29, 0.6);
            border: 1px solid var(--cafe-medio);
            border-radius: 12px;
            transition: all 0.3s ease;
            height: 100%;
            backdrop-filter: blur(4px);
        }

        .branch-card:hover {
            border-color: var(--dorado);
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            background-color: rgba(58, 42, 29, 0.8);
        }

        .branch-card .card-body {
            padding: 1.5rem;
        }

        .branch-name {
            color: var(--dorado);
            font-size: 1.2rem;
            font-weight: 500;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(198, 168, 125, 0.2);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .branch-name i {
            font-size: 1rem;
            color: #dc3545 !important;
        }

        /* Descripción con altura fija y scroll */
        .branch-description {
            color: var(--beige);
            font-size: 0.95rem;
            line-height: 1.6;
            opacity: 0.9;
            white-space: pre-line;
            max-height: 120px;
            overflow-y: auto;
            padding-right: 8px;
            margin-bottom: 1rem;
            scrollbar-width: thin;
            scrollbar-color: var(--dorado) var(--cafe-oscuro);
        }

        /* Scrollbar personalizada para la descripción */
        .branch-description::-webkit-scrollbar {
            width: 5px;
        }
        
        .branch-description::-webkit-scrollbar-track {
            background: var(--cafe-oscuro);
            border-radius: 10px;
        }
        
        .branch-description::-webkit-scrollbar-thumb {
            background: var(--dorado);
            border-radius: 10px;
        }
        
        .branch-description::-webkit-scrollbar-thumb:hover {
            background: var(--cafe-claro);
        }

        .branch-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 0.75rem;
            padding-top: 0.75rem;
            border-top: 1px solid rgba(198, 168, 125, 0.1);
        }

        .discount-badge {
            background: linear-gradient(to right, var(--cafe-medio), var(--cafe-oscuro));
            color: var(--dorado);
            font-size: 0.8rem;
            padding: 0.35rem 1rem;
            border-radius: 20px;
            border: 1px solid var(--dorado);
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
        }

        .discount-badge i {
            font-size: 0.75rem;
        }

        .branch-icon-right {
            color: var(--dorado);
            opacity: 0.5;
            transition: opacity 0.2s ease;
            font-size: 0.9rem;
        }

        .branch-card:hover .branch-icon-right {
            opacity: 1;
        }

        .empty-message {
            color: var(--beige);
            text-align: center;
            padding: 3rem;
            background-color: rgba(58, 42, 29, 0.4);
            border-radius: 12px;
            border: 1px dashed var(--cafe-medio);
        }

        .empty-message i {
            color: var(--dorado);
            margin-bottom: 1rem;
        }

        /* Grid de 2 columnas */
        .row {
            margin: -0.75rem;
        }
        .row > [class*="col-"] {
            padding: 0.75rem;
        }

        /* Scrollbar general */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--negro);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--cafe-medio);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--dorado);
        }

        @media (max-width: 768px) {
            .branches-container {
                padding: 1.5rem;
                margin: 1rem;
            }
            
            .branch-card .card-body {
                padding: 1.25rem;
            }
            
            .branch-description {
                max-height: 100px;
            }
        }
    </style>
</head>

<body class="body-content">
   
    <!-- Header -->
    {{> fragments/header}}
    
    <!-- Main Content -->
    <main class="container-fluid px-4">
        <div class="branches-container">
            <h1 class="branches-title">
                <i class="fas fa-store-alt me-2"></i>Nuestras Sucursales
            </h1>

            <div class="row">
                {{#branches}}
                <div class="col-md-6">
                    <div class="branch-card card">
                        <div class="card-body">
                            <!-- Nombre con icono rojo -->
                            <div class="branch-name">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>{{name}}</span>
                            </div>
                            
                            <!-- Descripción con scroll (MUY RÁPIDO) -->
                            <div class="branch-description">
                                {{description}}
                            </div>
                            
                            <!-- Footer -->
                            <div class="branch-footer">
                                <div>
                                    {{#purchaseDiscountPercent}}
                                    <span class="discount-badge">
                                        <i class="fas fa-tag"></i>
                                        {{purchaseDiscountPercent}}%
                                    </span>
                                    {{/purchaseDiscountPercent}}
                                </div>
                                <i class="fas fa-coffee branch-icon-right"></i>
                            </div>
                        </div>
                    </div>
                </div>
                {{/branches}}

                {{^branches}}
                <div class="col-12">
                    <div class="empty-message">
                        <i class="fas fa-store-alt fa-3x mb-3"></i>
                        <h4>No hay sucursales disponibles</h4>
                        <p class="text-muted">Pronto abriremos nuevas sucursales</p>
                    </div>
                </div>
                {{/branches}}
            </div>
        </div>
    </main>

    <!-- Footer -->
    {{> fragments/footer}}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>