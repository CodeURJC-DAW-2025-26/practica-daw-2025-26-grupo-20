<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/general.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/gestion_menu.css">
    <link rel="stylesheet" href="/css/menu.css">
</head>

<body class="body-content">
    {{> fragments/header}}

    <main class="container my-5 admin-container">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2>Gestión de Usuarios</h2>
            <button class="btn btn-header"
                onclick="document.getElementById('userForm').scrollIntoView({behavior: 'smooth'})">
                <i class="fas fa-user-plus me-2"></i>Nuevo Usuario
            </button>
        </div>

        <!-- User Form -->
        <div id="userForm" class="row justify-content-center mb-5">
            <div class="col-lg-8">
                <h4 class="mb-4" id="formTitle">Agregar Usuario</h4>
                <div class="form-container">
                    <form id="userFormEl" action="/admin/users/add" method="POST">
                        <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}" />
                        <input type="hidden" id="userId" name="id">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="userName" class="form-label">Nombre Completo</label>
                                <input type="text" class="form-control" id="userName" name="name"
                                    placeholder="Ej: Juan Pérez" required>
                            </div>
                            <div class="col-md-6">
                                <label for="userEmail" class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" id="userEmail" name="email"
                                    placeholder="ejemplo@correo.com" required>
                            </div>

                            <div class="col-md-6">
                                <label for="userRole" class="form-label">Rol</label>
                                <select class="form-select" id="userRole" name="role" required>
                                    <option value="" selected disabled>Seleccionar...</option>
                                    <option value="CUSTOMER">Cliente (CUSTOMER)</option>
                                    <option value="ADMIN">Administrador (ADMIN)</option>
                                </select>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="userPassword" class="form-label">Contraseña</label>
                                <input type="password" class="form-control" id="userPassword" name="password"
                                    placeholder="(Solo rellenar para cambiar)">
                                <small class="text-white-50 form-text">En nuevo usuario es obligatoria.</small>
                            </div>

                            <div class="col-md-12">
                                <label for="employeeId" class="form-label">ID Empleado</label>
                                <input type="text" class="form-control" id="employeeId" name="employeeId"
                                    placeholder="Ej: EMP-001">
                            </div>

                            <div class="col-12 mt-4 d-flex justify-content-end gap-2">
                                <button type="button" class="btn btn-secondary d-none" id="cancelEditBtn">Cancelar Edición</button>
                                <button type="submit" class="btn btn-header" id="submitBtn">Guardar Usuario</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Users List -->
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rol</th>
                        <th scope="col">ID Empleado</th>
                        <th scope="col" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#users}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{name}}</td>
                        <td>{{email}}</td>
                        <td>
                            {{#role}}
                                <span class="badge bg-primary">{{.}}</span>
                            {{/role}}
                        </td>
                        <td>{{#employeeId}}{{.}}{{/employeeId}}{{^employeeId}}N/A{{/employeeId}}</td>
                        <td class="text-end">
                            <button class="btn btn-action btn-edit" 
                                onclick="editUser('{{id}}', '{{name}}', '{{email}}', '{{role}}', '{{#employeeId}}{{.}}{{/employeeId}}')">
                                <i class="fas fa-edit"></i>
                            </button>
                            <form action="/admin/users/delete/{{id}}" method="POST" style="display:inline;">
                                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}" />
                                <button type="submit" class="btn btn-action btn-delete" onclick="return confirm('¿Estás seguro de que quieres eliminar a este usuario?');"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    {{/users}}
                </tbody>
            </table>
        </div>

        <script>
            function editUser(id, name, email, role, employeeId) {
                // Populate form
                document.getElementById('userId').value = id;
                document.getElementById('userName').value = name;
                document.getElementById('userEmail').value = email;
                document.getElementById('userRole').value = role;
                
                // Set employee ID or clear if null/undefined
                document.getElementById('employeeId').value = employeeId && employeeId !== 'null' ? employeeId : '';
                
                // Password should be empty and not required for edit
                document.getElementById('userPassword').value = '';
                document.getElementById('userPassword').required = false;
                
                // Employee ID is readonly during edit
                document.getElementById('employeeId').readOnly = true;

                // Change UI state
                document.getElementById('formTitle').innerText = 'Actualizar Usuario';
                document.getElementById('submitBtn').innerText = 'Actualizar Usuario';
                document.getElementById('cancelEditBtn').classList.remove('d-none');
                
                // Change form action
                document.getElementById('userFormEl').action = '/admin/users/edit';

                // Scroll to form
                document.getElementById('userForm').scrollIntoView({behavior: 'smooth'});
            }

            document.getElementById('cancelEditBtn').addEventListener('click', function() {
                // Reset form
                document.getElementById('userFormEl').reset();
                document.getElementById('userId').value = '';

                // Restore UI state
                document.getElementById('userPassword').required = true;
                document.getElementById('employeeId').readOnly = true;
                document.getElementById('formTitle').innerText = 'Agregar Usuario';
                document.getElementById('submitBtn').innerText = 'Guardar Usuario';
                this.classList.add('d-none');

                // Reset form action
                document.getElementById('userFormEl').action = '/admin/users/add';
            });
            
            // Password logic for new users
            document.getElementById('userFormEl').addEventListener('submit', function(e) {
                const isEditing = document.getElementById('userId').value !== '';
                const pwdField = document.getElementById('userPassword');
                
                if (!isEditing && pwdField.value.trim() === '') {
                    e.preventDefault();
                    alert('Por favor, ingresa una contraseña para el nuevo usuario.');
                }
            });
        </script>

        <hr class="my-5" style="border-color: var(--dorado); opacity: 0.3;">

        {{> fragments/footer}}

</body>

</html>
